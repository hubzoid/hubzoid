.DS_Store
.env

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/

# Test + tooling caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Open WebUI per hub state
.openwebui-data/

# Per session hub outputs
**/output/

# Playwright MCP local cache (test artifacts; never tracked)
.playwright-mcp/

# Stray E2E screenshots Playwright drops in the repo root when called
# from a Claude session whose cwd is here. Intentional copies live in
# ../HubzoidTests/reports/ (a separate folder, outside this repo).
# The leading slash anchors the pattern to repo root only, so
# demo-hub/branding/*.png and hubzoid/templates/starter/branding/*.png
# are NOT excluded.
/demo-hub-*.png
