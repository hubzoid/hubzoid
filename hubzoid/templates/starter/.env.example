# Copy to .env and fill in. .env is git-ignored.
#
# Pick ONE provider stanza below. The MODEL string tells hubzoid (via LiteLLM)
# which provider to call; the matching API key must be set.

# --- OpenRouter (one key, many models) -------------------------------------
OPENROUTER_API_KEY=
MODEL=openrouter/anthropic/claude-haiku-4.5

# --- OpenAI -----------------------------------------------------------------
# OPENAI_API_KEY=
# MODEL=openai/gpt-4o-mini

# --- Anthropic --------------------------------------------------------------
# ANTHROPIC_API_KEY=
# MODEL=anthropic/claude-haiku-4-5

# --- Claude local (use your installed `claude` CLI + subscription) ---------
# No API key needed. Requires:
#   - `claude` CLI installed and logged in (`claude login`)
#   - `pip install 'hubzoid[claude-local]'`
# Usage on Pro/Max plans draws from your Agent SDK monthly credit.
# MODEL=claude-local

# --- Bridge / UI knobs (optional) -------------------------------------------
# BRIDGE_API_KEYS=dev           # comma-separated; first one is what Open WebUI sees
# MODEL_LABEL=                  # what /v1/models reports; blank = derive from AGENTS.md name
# WEBUI_NAME=                   # Open WebUI title; blank = default
# PORT=3080                     # Open WebUI port
# BRIDGE_PORT=8000              # FastAPI bridge port
# HTTP_ALLOWLIST=               # comma-separated hostnames the http_get tool may visit
